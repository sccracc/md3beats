rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /news/{docId} {
      allow read: if resource.data.status == "published";
      allow read, write: if request.auth != null;
    }
    match /inquiries/{docId} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
  }
}
